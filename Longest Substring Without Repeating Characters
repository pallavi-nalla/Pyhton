s = input("Enter any string: ")
d = {}
left = 0
max_len = 0
start = 0  
for right in range(len(s)):
    if s[right] in d and d[s[right]] >= left:
        left = d[s[right]] + 1
    d[s[right]] = right
    if right - left + 1 > max_len:
        max_len = right - left + 1
        start = left
print("Longest substring:", s[start:start + max_len])
print("Length:", max_len)
